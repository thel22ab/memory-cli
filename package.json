{
  "name": "mac-memory-cli",
  "version": "0.1.0",
  "description": "Lightweight macOS terminal memory manager for memory pressure triage.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thel22ab/memory-cli.git"
  },
  "homepage": "https://github.com/thel22ab/memory-cli#readme",
  "bugs": {
    "url": "https://github.com/thel22ab/memory-cli/issues"
  },
  "bin": {
    "memory-cli": "src/index.ts"
  },
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "dev": "bun run src/index.ts",
    "start": "bun dist/index.js",
    "lint": "eslint .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit"
  },
  "packageManager": "bun@1.3.3",
  "engines": {
    "bun": ">=1.3.3"
  },
  "dependencies": {
    "neo-blessed": "^0.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/blessed": "^0.1.27",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
